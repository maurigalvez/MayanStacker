  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The stones remember \u2014 even when the world forgets.\n\nOnce a major
    Maya city, Edzn\xE1\u2019s name \u2014 \u201CHouse of the Itzaes\u201D \u2014
    still echoes through its ruins.\n\nHighlights\nGreat Temple: 40-meter pyramid
    overlooking the plaza\nBall Court: Parallel walls marking the site of sacred
    games\n\nTimeline\n400 BC: First settlers\n200 AD: Height of power\nInfluenced
    by Calakmul and Puuc styles\n~1500 AD: Abandoned\n\nRediscovery\nFound in 1907,
    excavated in 1958, and restored in 1986 with international support."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
